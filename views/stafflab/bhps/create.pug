extends ../../layouts/master.pug

block content
  .row
    .col-12
      .card.bg-light-primary.shadow-none.position-relative.overflow-hidden.mb-4
        .card-body.px-4.py-3
          .row.align-items-center
            .col-9
              h4.fw-semibold.mb-8 Tambah BHP Baru
              nav(aria-label="breadcrumb")
                ol.breadcrumb.mb-0
                  li.breadcrumb-item
                    a.text-muted.text-decoration-none(href="/dashboard") Dashboard
                  li.breadcrumb-item
                    a.text-muted.text-decoration-none(href="/stafflab/bhps") Stok BHP
                  li.breadcrumb-item.text-muted.active(aria-current="page") Tambah BHP
            .col-3
              .text-center.mb-n5
                img.img-fluid.mb-n4(src="/assets/images/backgrounds/welcome-bg.svg" alt="" style="max-height: 120px;")

  if error
    .alert.alert-danger.alert-dismissible.fade.show(role="alert")
      i.fa.fa-exclamation-circle.me-2
      strong Error! 
      = error
      button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

  .row
    .col-lg-6
      .card
        .card-body
          h5.card-title.fw-semibold.mb-4 Formulir BHP Baru
          form(action="/stafflab/bhps" method="POST")
            .mb-3
              label.form-label Nama Bahan Habis Pakai
              input.form-control(type="text" name="name" placeholder="Contoh: Kertas A4, Timah Solder, Alkohol 70%" value=(formData.name || '') required autofocus)
            .mb-3
              label.form-label Satuan
              input.form-control(type="text" name="unit" placeholder="Contoh: rim, roll, botol, pcs" value=(formData.unit || '') required)
            .mb-3
              label.form-label Stok Awal
              input.form-control(type="number" name="stock" placeholder="Contoh: 10" value=(formData.stock !== undefined ? formData.stock : 0) min="0" required)
              p.small.text-muted.mb-0 Stok awal dari barang yang didaftarkan.
            .d-flex.gap-2.mt-4
              button.btn.btn-primary(type="submit")
                i.ti.ti-device-floppy.me-1
                | Simpan
              a.btn.btn-outline-secondary(href="/stafflab/bhps") Batal
