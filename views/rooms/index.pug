extends ../layouts/master.pug

block content
  .row
    .col-12
      .card.bg-light-primary.shadow-none.position-relative.overflow-hidden.mb-4
        .card-body.px-4.py-3
          .row.align-items-center
            .col-9
              h4.fw-semibold.mb-8 Ruangan Laboratorium
              nav(aria-label="breadcrumb")
                ol.breadcrumb.mb-0
                  li.breadcrumb-item
                    a.text-muted.text-decoration-none(href="/dashboard") Dashboard
                  li.breadcrumb-item.text-muted.active(aria-current="page") Ruangan Lab
            .col-3
              .text-center.mb-n5
                img.img-fluid.mb-n4(src="/assets/images/backgrounds/welcome-bg.svg" alt="" style="max-height: 120px;")

  //- Success & Error Alerts
  if success
    .alert.alert-success.alert-dismissible.fade.show(role="alert")
      i.fa.fa-check-circle.me-2
      strong Sukses! 
      = success
      button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")
  if error
    .alert.alert-danger.alert-dismissible.fade.show(role="alert")
      i.fa.fa-exclamation-circle.me-2
      strong Error! 
      = error
      button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

  .row
    .col-12
      .card.w-100
        .card-body
          .d-flex.align-items-center.justify-content-between.mb-4
            div
              h5.card-title.fw-semibold.mb-0 Daftar Ruangan Lab
              p.card-subtitle.mb-0 Daftar ruangan laboratorium yang digunakan untuk menempatkan barang inventaris.
            if user && user.role === 'Administrator'
              a.btn.btn-primary.d-flex.align-items-center.gap-2(href="/rooms/create")
                i.ti.ti-plus.fs-5
                | Tambah Ruangan

          .table-responsive.mt-4
            table.table.align-middle.text-nowrap.mb-0
              thead.text-dark.fs-4
                tr
                  th.border-bottom-0.fw-semibold No
                  th.border-bottom-0.fw-semibold Nama Ruangan
                  th.border-bottom-0.fw-semibold Kode Ruangan
                  th.border-bottom-0.fw-semibold Lokasi
                  th.border-bottom-0.fw-semibold Deskripsi / Keterangan
                  if user && user.role === 'Administrator'
                    th.border-bottom-0.fw-semibold.text-center Aksi
              tbody
                if rooms && rooms.length > 0
                  each room, index in rooms
                    tr
                      td.border-bottom-0
                        h6.fw-normal.mb-0= index + 1
                      td.border-bottom-0
                        h6.fw-semibold.mb-0= room.name
                      td.border-bottom-0
                        span.badge.bg-light-secondary.text-secondary.fw-semibold= room.code || '-'
                      td.border-bottom-0
                        span.badge.bg-light-secondary.text-secondary.fw-semibold= room.location || '-'
                      td.border-bottom-0
                        p.mb-0.fw-normal.text-wrap(style="max-width: 350px;")= room.description || '-'
                      if user && user.role === 'Administrator'
                        td.border-bottom-0.text-center
                          .d-flex.justify-content-center.gap-2
                            a.btn.btn-sm.btn-outline-warning.d-flex.align-items-center.gap-1(href=`/rooms/edit/${room.id}`)
                              i.ti.ti-edit
                              | Ubah
                            form(action=`/rooms/delete/${room.id}` method="POST" onsubmit="return confirm('Apakah Anda yakin ingin menghapus ruangan ini? Inventaris yang terikat di ruangan ini mungkin akan kehilangan referensi.')")
                              button.btn.btn-sm.btn-outline-danger.d-flex.align-items-center.gap-1(type="submit")
                                i.ti.ti-trash
                                | Hapus
                else
                  tr
                    td.text-center.py-4(colspan=(user && user.role === 'Administrator' ? 5 : 4)) Belum ada data ruangan laboratorium.
