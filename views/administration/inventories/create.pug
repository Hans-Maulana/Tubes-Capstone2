extends ../../layouts/master.pug

block content
  .row
    .col-12
      .card.bg-light-primary.shadow-none.position-relative.overflow-hidden.mb-4
        .card-body.px-4.py-3
          .row.align-items-center
            .col-9
              h4.fw-semibold.mb-8 Input Label (1 Unit)
              nav(aria-label="breadcrumb")
                ol.breadcrumb.mb-0
                  li.breadcrumb-item
                    a.text-muted.text-decoration-none(href="/dashboard") Dashboard
                  li.breadcrumb-item
                    a.text-muted.text-decoration-none(href="/administration/inventories") Input Inventaris
                  li.breadcrumb-item.text-muted.active(aria-current="page") Input Label
            .col-3
              .text-center.mb-n5
                img.img-fluid.mb-n4(src="/assets/images/backgrounds/welcome-bg.svg" alt="" style="max-height: 120px;")

  if error
    .alert.alert-danger.alert-dismissible.fade.show(role="alert")
      i.fa.fa-exclamation-circle.me-2
      strong Error! 
      = error
      button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

  .row
    .col-lg-8
      .card
        .card-body
          h5.card-title.fw-semibold.mb-2 Input 1 Label untuk 1 Unit Barang
          p.card-subtitle.mb-4 Setiap simpan hanya membuat satu inventaris dengan satu nomor label dan satu QR code.

          if selectedItem && progress
            .alert.alert-light.border.mb-4
              .d-flex.align-items-center.justify-content-between.flex-wrap.gap-2
                div
                  p.mb-1.text-muted.small Item Pengadaan
                  h6.fw-semibold.mb-0= selectedItem.item_name
                  p.mb-0.text-muted.small= `Tahun ${selectedItem.draft ? selectedItem.draft.year : '-'} • Jenis ${selectedItem.item_type}`
                span.badge.bg-primary.rounded-3.fw-semibold= `Unit ke-${progress.nextUnit} dari ${progress.received} diterima`
              p.small.text-muted.mt-2.mb-0= `Jumlah disetujui pengadaan: ${progress.approved} unit`

            form(action="/administration/inventories" method="POST" onsubmit="return confirm('Simpan 1 label dan generate QR code untuk unit ini?')")
              input(type="hidden" name="procurement_item_id" value=selectedItem.id)
              .row
                .col-md-6.mb-3
                  label.form-label Kondisi
                  select.form-select(name="condition" required)
                    - const selectedCondition = (formData.condition || 'Baik')
                    option(value="Baik" selected=(selectedCondition === 'Baik')) Baik
                    option(value="Maintenance" selected=(selectedCondition === 'Maintenance')) Maintenance
                    option(value="Rusak" selected=(selectedCondition === 'Rusak')) Rusak
                .col-md-6.mb-3
                  label.form-label Ruangan
                  select.form-select(name="room_id" required)
                    option(value="" disabled selected=(!formData.room_id)) -- Pilih Ruangan --
                    each room in (rooms || [])
                      option(value=room.id selected=(String(formData.room_id) === String(room.id)))= room.name
                  if rooms && rooms.length > 0
                    p.small.text-muted.mb-0.mt-1= `Daftar ruangan: ${rooms.map(r => r.name).join(', ')}`
                  else
                    p.small.text-danger.mb-0.mt-1 Data ruangan kosong. Jalankan seeder room terlebih dahulu.
              .mb-3
                label.form-label Nomor Label (1 unit)
                input.form-control(type="text" name="label_number" placeholder="Contoh: LAB-INV-2026-001" value=(formData.label_number || '') required autofocus)
                p.small.text-muted.mb-0 Satu form ini hanya untuk satu nomor label. Setelah simpan, Anda bisa langsung input label berikutnya untuk unit selanjutnya.
              .d-flex.gap-2
                button.btn.btn-primary(type="submit")
                  i.ti.ti-qrcode.me-1
                  | Simpan 1 Label & Generate QR
                a.btn.btn-outline-secondary(href="/administration/inventories") Kembali ke Daftar
          else
            .alert.alert-warning.mb-0
              i.ti.ti-info-circle.me-1
              | Item pengadaan tidak ditemukan. Silakan pilih item dari halaman Input Inventaris.
