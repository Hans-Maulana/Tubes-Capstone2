doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title= title || 'Register - Sistem Inventaris Laboratorium'
    link(rel="shortcut icon" type="image/png" href="/assets/images/logos/favicon.png")
    link(rel="stylesheet" href="/assets/css/styles.min.css")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
    style.
      body {
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow-x: hidden;
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
      }
      .form-control, .form-select {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        border-radius: 10px;
        padding: 12px 16px;
      }
      .form-control:focus, .form-select:focus {
        border-color: #5d87ff !important;
        box-shadow: 0 0 0 0.25rem rgba(93, 135, 255, 0.25) !important;
      }
      .form-select option {
        background: #1e1b4b;
        color: #fff;
      }
      .form-label {
        color: #cbd5e1;
        font-weight: 500;
      }

  body
    .position-relative.overflow-hidden.w-100.d-flex.align-items-center.justify-content-center
      .d-flex.align-items-center.justify-content-center.w-100(style="max-width: 480px; padding: 20px;")
        .card.glass-card.w-100.mb-0
          .card-body.p-4.p-sm-5
            .text-center.mb-4
              span.text-nowrap.logo-img.text-center.d-block.w-100
                h2.fw-bold.text-white.mb-1
                  i.fa.fa-cubes.text-primary.me-2
                  | BUAT AKUN
              p.text-muted.small Silakan daftarkan akun baru untuk mengelola sistem
            
            if error
              .alert.alert-danger.border-0.bg-danger.text-white.rounded-3.py-2.px-3.mb-3(role="alert")
                i.fa.fa-triangle-exclamation.me-2.small
                span.small= error
            
            form(action="/auth/register" method="POST")
              .mb-3
                label.form-label(for="name") Nama Lengkap
                input#name.form-control(type="text" name="name" placeholder="John Doe" required)
              .mb-3
                label.form-label(for="email") Alamat Email
                input#email.form-control(type="email" name="email" placeholder="nama@email.com" required)
              .mb-3
                label.form-label(for="role_id") Peran / Jabatan
                select#role_id.form-select(name="role_id" required)
                  if roles && roles.length > 0
                    each r in roles
                      option(value=r.id)= r.name
                  else
                    option(value="1") Administrator
                    option(value="2") Kepala Laboratorium
                    option(value="3") Staf Laboratorium
                    option(value="4") Staf Administrasi
              .mb-4
                label.form-label(for="password") Password
                input#password.form-control(type="password" name="password" placeholder="••••••••" required)
                
              button.btn.btn-primary.w-100.py-8.fs-4.mb-4.rounded-2(type="submit" style="font-weight: 600;") Daftar Akun
              
              .d-flex.align-items-center.justify-content-center
                p.mb-0.fw-bold.text-muted Sudah memiliki akun?
                a.text-primary.fw-bold.ms-2(href="/auth/login" style="text-decoration: none;") Masuk Disini
