doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title || '403 Forbidden - Access Denied'
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    
    style.
      body {
        font-family: 'Outfit', sans-serif;
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #450a0a 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
      }
      
      /* Glowing backdrops */
      .blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(90px);
        opacity: 0.15;
        z-index: 1;
        animation: float 12s ease-in-out infinite;
      }
      .blob-1 {
        background: #ef4444;
        width: 320px;
        height: 320px;
        top: 15%;
        left: 10%;
      }
      .blob-2 {
        background: #a855f7;
        width: 380px;
        height: 380px;
        bottom: 15%;
        right: 10%;
        animation-delay: -6s;
      }
      
      @keyframes float {
        0%, 100% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-25px) scale(1.08); }
      }
      
      .error-container {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 500px;
        padding: 20px;
        text-align: center;
      }
      
      .glass-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px) saturate(140%);
        -webkit-backdrop-filter: blur(20px) saturate(140%);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 28px;
        padding: 50px 40px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
        color: #f8fafc;
      }
      
      .glowing-shield {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.25);
        border-radius: 50%;
        width: 90px;
        height: 90px;
        margin-bottom: 25px;
        box-shadow: 0 0 30px rgba(239, 68, 68, 0.15);
        animation: pulse 2s infinite alternate;
      }
      
      @keyframes pulse {
        0% { box-shadow: 0 0 20px rgba(239, 68, 68, 0.15); }
        100% { box-shadow: 0 0 40px rgba(239, 68, 68, 0.35); }
      }
      
      .error-code {
        font-size: 72px;
        font-weight: 800;
        background: linear-gradient(to right, #f87171, #c084fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1;
        margin-bottom: 10px;
        letter-spacing: -2px;
      }
      
      .error-title {
        font-weight: 700;
        font-size: 22px;
        margin-bottom: 15px;
        color: #ffffff;
      }
      
      .error-desc {
        color: #94a3b8;
        font-size: 15px;
        line-height: 1.6;
        margin-bottom: 30px;
      }
      
      .btn-back {
        background: linear-gradient(135deg, #ef4444 0%, #a855f7 100%);
        border: none;
        color: #ffffff;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 12px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(239, 68, 68, 0.25);
        text-decoration: none;
        display: inline-block;
      }
      
      .btn-back:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(239, 68, 68, 0.45);
        color: #ffffff;
      }
      
      .btn-outline-glass {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #cbd5e1;
        font-weight: 500;
        padding: 12px 24px;
        border-radius: 12px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        margin-left: 10px;
      }
      
      .btn-outline-glass:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #ffffff;
      }
      
      .footer-text {
        color: #475569;
        font-size: 13px;
        margin-top: 30px;
      }

  body
    .blob.blob-1
    .blob.blob-2
    
    .error-container
      .glass-card
        .glowing-shield
          i.fa.fa-shield-halved.fs-1.text-danger
          
        .error-code 403
        .error-title Akses Ditolak (Forbidden)
        
        .error-desc
          if message
            = message
          else
            | Maaf, Anda tidak memiliki izin atau hak akses untuk melihat halaman ini. Silakan kembali ke dashboard utama atau hubungi Administrator.
            
        .actions.d-flex.justify-content-center
          a.btn.btn-back(href="/dashboard")
            i.fa.fa-arrow-left.me-2
            | Kembali ke Dashboard
          a.btn.btn-outline-glass(href="/auth/logout")
            i.fa.fa-sign-out-alt.me-2
            | Keluar Sesi
            
        .footer-text
          span Copyright &copy; 2026 &bull; Tubes PWL Capstone II
