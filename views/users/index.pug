extends ../layouts/master.pug

block content
  .row
    .col-12
      .card.bg-light-primary.shadow-none.position-relative.overflow-hidden.mb-4
        .card-body.px-4.py-3
          .row.align-items-center
            .col-9
              h4.fw-semibold.mb-8 Kelola Pengguna
              nav(aria-label="breadcrumb")
                ol.breadcrumb.mb-0
                  li.breadcrumb-item
                    a.text-muted.text-decoration-none(href="/dashboard") Dashboard
                  li.breadcrumb-item.text-muted.active(aria-current="page") Daftar Pengguna
            .col-3
              .text-center.mb-n5
                img.img-fluid.mb-n4(src="/assets/images/backgrounds/welcome-bg.svg" alt="" style="max-height: 120px;")

  //- Success & Error Alerts
  if success
    .alert.alert-success.alert-dismissible.fade.show(role="alert")
      i.fa.fa-check-circle.me-2
      strong Sukses! 
      = success
      button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")
  if error
    .alert.alert-danger.alert-dismissible.fade.show(role="alert")
      i.fa.fa-exclamation-circle.me-2
      strong Error! 
      = error
      button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

  .row
    .col-12
      .card.w-100
        .card-body
          .d-flex.align-items-center.justify-content-between.mb-4
            div
              h5.card-title.fw-semibold.mb-0 Pengguna Sistem
              p.card-subtitle.mb-0 Daftar semua pengguna yang terdaftar di dalam sistem inventaris.
            a.btn.btn-primary.d-flex.align-items-center.gap-2(href="/users/create")
              i.ti.ti-user-plus.fs-5
              | Tambah Pengguna

          .table-responsive.mt-4
            table.table.align-middle.text-nowrap.mb-0
              thead.text-dark.fs-4
                tr
                  th.border-bottom-0.fw-semibold No
                  th.border-bottom-0.fw-semibold Nama Lengkap
                  th.border-bottom-0.fw-semibold Email
                  th.border-bottom-0.fw-semibold Peran (Role)
                  th.border-bottom-0.fw-semibold Tanggal Terdaftar
                  th.border-bottom-0.fw-semibold.text-center Aksi
              tbody
                if users && users.length > 0
                  each userItem, index in users
                    tr
                      td.border-bottom-0
                        h6.fw-normal.mb-0= index + 1
                      td.border-bottom-0
                        h6.fw-semibold.mb-0= userItem.name
                        if user && user.id === userItem.id
                          span.badge.bg-primary.rounded-3.fw-semibold Anda
                      td.border-bottom-0
                        p.mb-0.fw-normal= userItem.email
                      td.border-bottom-0
                        if userItem.role
                          if userItem.role.name === 'Administrator'
                            span.badge.bg-danger.rounded-3.fw-semibold= userItem.role.name
                          else if userItem.role.name === 'Kepala Laboratorium'
                            span.badge.bg-warning.rounded-3.fw-semibold= userItem.role.name
                          else
                            span.badge.bg-primary.rounded-3.fw-semibold= userItem.role.name
                        else
                          span.badge.bg-secondary.rounded-3.fw-semibold Tanpa Peran
                      td.border-bottom-0
                        span.fw-normal= new Date(userItem.createdAt).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })
                      td.border-bottom-0.text-center
                        .d-flex.justify-content-center.gap-2
                          a.btn.btn-sm.btn-outline-warning.d-flex.align-items-center.gap-1(href=`/users/edit/${userItem.id}`)
                            i.ti.ti-edit
                            | Ubah
                          
                          if !user || user.id !== userItem.id
                            form(action=`/users/delete/${userItem.id}` method="POST" onsubmit="return confirm('Apakah Anda yakin ingin menghapus pengguna ini? Tindakan ini tidak dapat dibatalkan.')")
                              button.btn.btn-sm.btn-outline-danger.d-flex.align-items-center.gap-1(type="submit")
                                i.ti.ti-trash
                                | Hapus
                          else
                            button.btn.btn-sm.btn-outline-secondary.d-flex.align-items-center.gap-1(disabled title="Tidak bisa menghapus diri sendiri")
                              i.ti.ti-trash
                              | Hapus
                else
                  tr
                    td.text-center.py-4(colspan="6") Belum ada data pengguna terdaftar.
